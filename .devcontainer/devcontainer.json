{
  "name": "uav-cyber-sim (X11 over SSH)",
  "image": "uav-cyber-sim-main:latest",
  // "build": {
  //   "context": "..",
  //   "dockerfile": "Dockerfile",
  //   "args": {
  //     "UID": "1001",
  //     "GID": "1001"
  //   }
  // },
  "runArgs": [
    "--network",
    "host"
  ],
  "containerEnv": {
    "DISPLAY": "${env:DISPLAY}"
  },
  "mounts": [
    "type=bind,source=/tmp/.X11-unix,target=/tmp/.X11-unix"
  ],
  "postAttachCommand": "sudo chown -R ubuntu /workspaces",
  // "customizations": {
  //   "vscode": {
  //     "extensions": [
  //       "ms-toolsai.jupyter@2025.6.0",
  //       "ms-python.python"
  //     ]
  //   }
  //},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": false
}